# Copy this file to .env and edit. Bun loads .env automatically.

# Who may trigger downloads in direct chats:
#   anyone = any DM, from other people and your own self-chat (default)
#   self   = only your own self-chat
#   off    = ignore DMs
PING_DMS=anyone

# How the bot behaves in group chats:
#   mention = only when you are tagged in the message (default)
#   all     = any link anyone posts in a group
#   off     = ignore groups
PING_GROUPS=mention

# Instagram login cookies for gallery-dl (Instagram is the only platform that
# needs them for now). Set ONE of these. cookies.txt is the Netscape format
# exported by a browser extension like "Get cookies.txt".
#
# Option A: a path to the file
# GALLERY_DL_COOKIES=/absolute/path/to/cookies.txt
#
# Option B: the file base64-encoded (decoded to a temp file at runtime)
#   make it with:  base64 -i cookies.txt | tr -d '\n'
# GALLERY_DL_COOKIES_B64=
